{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pehchaan-careers.local/schemas/skill_map.schema.json",
  "type": "object",
  "required": ["meta", "skill_map"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["quality_policy"],
      "properties": {
        "quality_policy": { "$ref": "#/$defs/quality_policy" }
      },
      "additionalProperties": true
    },
    "skill_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "skill_id",
          "career_id",
          "learning_sequence",
          "time_commitment",
          "provenance",
          "freshness",
          "contradiction_handling"
        ],
        "properties": {
          "skill_id": { "type": "string" },
          "career_id": { "type": "string" },
          "language_availability": { "type": "array", "items": { "type": "string" } },
          "time_to_mastery": { "type": "string" },
          "prerequisite_skills": { "type": "array", "items": { "type": "string" } },
          "industry_recognition": { "type": "string" },
          "time_commitment": { "type": "integer", "minimum": 1 },
          "learning_sequence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["step_number", "resource_id", "cost_type", "language_tags"],
              "properties": {
                "step_number": { "type": "integer", "minimum": 1 },
                "resource_id": { "type": "string" },
                "cost_type": { "type": "string", "enum": ["Free", "Paid", "Freemium"] },
                "language_tags": { "type": "array", "items": { "type": "string" } }
              },
              "additionalProperties": true
            }
          },
          "provenance": { "$ref": "#/$defs/provenance" },
          "freshness": { "$ref": "#/$defs/freshness" },
          "contradiction_handling": { "$ref": "#/$defs/contradiction_handling" }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "required": ["sources", "confidence"],
      "properties": {
        "sources": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "freshness": {
      "type": "object",
      "required": ["last_verified_on", "review_cycle_days"],
      "properties": {
        "last_verified_on": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "review_cycle_days": { "type": "integer", "minimum": 1, "maximum": 365 }
      },
      "additionalProperties": true
    },
    "contradiction_handling": {
      "type": "object",
      "required": ["status", "resolution_policy", "conflicting_source_count"],
      "properties": {
        "status": { "type": "string", "enum": ["none", "under_review", "resolved"] },
        "resolution_policy": {
          "type": "string",
          "enum": ["higher_confidence_wins", "manual_editor_review", "latest_verified_source"]
        },
        "conflicting_source_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "quality_policy": {
      "type": "object",
      "required": ["confidence_scale", "freshness_sla_days", "contradiction_rules"],
      "properties": {
        "confidence_scale": { "type": "string" },
        "freshness_sla_days": { "type": "integer", "minimum": 1, "maximum": 365 },
        "contradiction_rules": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
