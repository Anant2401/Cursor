{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pehchaan-careers.local/schemas/careers.schema.json",
  "type": "object",
  "required": ["meta", "careers"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["schema_version", "generated_on", "quality_policy"],
      "properties": {
        "schema_version": { "type": "string" },
        "generated_on": { "type": "string" },
        "source_files": { "type": "array", "items": { "type": "string" } },
        "quality_policy": { "$ref": "#/$defs/quality_policy" }
      },
      "additionalProperties": true
    },
    "careers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "career_id",
          "name",
          "career_tier",
          "ai_impact_score",
          "remote_index",
          "roi_index",
          "salary_structure",
          "national_demand",
          "skills",
          "exams",
          "typical_employers",
          "provenance",
          "freshness",
          "contradiction_handling"
        ],
        "properties": {
          "career_id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "career_tier": {
            "type": "string",
            "enum": ["Blue Collar", "Grey Collar", "White Collar", "Professional"]
          },
          "ai_impact_score": { "type": "integer", "minimum": 1, "maximum": 10 },
          "remote_index": { "type": "integer", "minimum": 1, "maximum": 10 },
          "roi_index": { "type": "number", "minimum": 1, "maximum": 10 },
          "salary_structure": {
            "type": "object",
            "required": ["tier_1_city", "tier_2_city", "fresher_avg"],
            "properties": {
              "tier_1_city": { "type": "string" },
              "tier_2_city": { "type": "string" },
              "fresher_avg": { "type": "string" }
            },
            "additionalProperties": true
          },
          "national_demand": { "type": "string" },
          "lateral_entry_paths": { "type": "array", "items": { "type": "string" } },
          "skills": { "type": "array", "items": { "type": "string" } },
          "exams": { "type": "array", "items": { "type": "string" } },
          "typical_employers": { "type": "array", "items": { "type": "string" } },
          "hidden_costs": { "type": "object" },
          "physical_mental_demands": { "type": "object" },
          "gig_economy_viability": { "type": "boolean" },
          "state_dynamics": { "type": "object" },
          "provenance": { "$ref": "#/$defs/provenance" },
          "freshness": { "$ref": "#/$defs/freshness" },
          "contradiction_handling": { "$ref": "#/$defs/contradiction_handling" },
          "legacy_refs": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "required": ["sources", "confidence"],
      "properties": {
        "sources": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "freshness": {
      "type": "object",
      "required": ["last_verified_on", "review_cycle_days"],
      "properties": {
        "last_verified_on": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "review_cycle_days": { "type": "integer", "minimum": 1, "maximum": 365 }
      },
      "additionalProperties": true
    },
    "contradiction_handling": {
      "type": "object",
      "required": ["status", "resolution_policy", "conflicting_source_count"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["none", "under_review", "resolved"]
        },
        "resolution_policy": {
          "type": "string",
          "enum": ["higher_confidence_wins", "manual_editor_review", "latest_verified_source"]
        },
        "conflicting_source_count": { "type": "integer", "minimum": 0 },
        "resolution_notes": { "type": "string" },
        "last_reviewed_on": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      },
      "additionalProperties": true
    },
    "quality_policy": {
      "type": "object",
      "required": [
        "confidence_scale",
        "default_review_cycle_days",
        "freshness_sla_days",
        "contradiction_rules"
      ],
      "properties": {
        "confidence_scale": { "type": "string" },
        "default_review_cycle_days": { "type": "integer", "minimum": 1, "maximum": 365 },
        "freshness_sla_days": { "type": "integer", "minimum": 1, "maximum": 365 },
        "contradiction_rules": {
          "type": "object",
          "required": ["auto_flag_threshold", "default_resolution_policy"],
          "properties": {
            "auto_flag_threshold": { "type": "integer", "minimum": 1 },
            "default_resolution_policy": {
              "type": "string",
              "enum": ["higher_confidence_wins", "manual_editor_review", "latest_verified_source"]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
