{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pehchaan-careers.local/schemas/institutions.schema.json",
  "type": "object",
  "required": ["meta", "institutions"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["quality_policy"],
      "properties": {
        "quality_policy": { "$ref": "#/$defs/quality_policy" }
      },
      "additionalProperties": true
    },
    "institutions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["institution_id", "name", "state_id", "city", "provenance", "freshness", "contradiction_handling"],
        "properties": {
          "institution_id": { "type": "string" },
          "name": { "type": "string" },
          "state_id": { "type": "string" },
          "city": { "type": "string" },
          "nirf_rank": { "type": ["integer", "null"] },
          "naac_rating": { "type": ["string", "null"] },
          "placement_reality": { "type": "object" },
          "cutoff_history": { "type": "object" },
          "infrastructure_score": { "type": "object" },
          "faculty_to_student_ratio": { "type": "string" },
          "programs": { "type": "array", "items": { "type": "object" } },
          "provenance": { "$ref": "#/$defs/provenance" },
          "freshness": { "$ref": "#/$defs/freshness" },
          "contradiction_handling": { "$ref": "#/$defs/contradiction_handling" }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "required": ["sources", "confidence"],
      "properties": {
        "sources": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "freshness": {
      "type": "object",
      "required": ["last_verified_on", "review_cycle_days"],
      "properties": {
        "last_verified_on": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "review_cycle_days": { "type": "integer", "minimum": 1, "maximum": 365 }
      },
      "additionalProperties": true
    },
    "contradiction_handling": {
      "type": "object",
      "required": ["status", "resolution_policy", "conflicting_source_count"],
      "properties": {
        "status": { "type": "string", "enum": ["none", "under_review", "resolved"] },
        "resolution_policy": {
          "type": "string",
          "enum": ["higher_confidence_wins", "manual_editor_review", "latest_verified_source"]
        },
        "conflicting_source_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "quality_policy": {
      "type": "object",
      "required": ["confidence_scale", "freshness_sla_days", "contradiction_rules"],
      "properties": {
        "confidence_scale": { "type": "string" },
        "freshness_sla_days": { "type": "integer", "minimum": 1, "maximum": 365 },
        "contradiction_rules": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
