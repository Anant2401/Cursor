{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pehchaan-careers.local/schemas/resources.schema.json",
  "type": "object",
  "required": ["meta", "resources"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["schema_version", "generated_on", "source_files", "quality_metadata", "language_coverage", "quality_policy"],
      "properties": {
        "schema_version": { "type": "string" },
        "generated_on": { "type": "string" },
        "source_files": { "type": "array", "items": { "type": "string" } },
        "quality_metadata": {
          "type": "object",
          "required": ["confidence_scale", "quality_tiers", "default_quality_tier"],
          "properties": {
            "confidence_scale": { "type": "string" },
            "quality_tiers": { "type": "array", "items": { "type": "string" } },
            "default_quality_tier": { "type": "string" }
          },
          "additionalProperties": true
        },
        "language_coverage": {
          "type": "object",
          "required": ["supported_languages", "minimum_languages_per_resource"],
          "properties": {
            "supported_languages": { "type": "array", "items": { "type": "string" } },
            "minimum_languages_per_resource": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": true
        },
        "quality_policy": { "$ref": "#/$defs/quality_policy" }
      },
      "additionalProperties": true
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "resource_id",
          "title",
          "url",
          "platform",
          "language_tags",
          "cost_type",
          "provenance",
          "freshness",
          "contradiction_handling"
        ],
        "properties": {
          "resource_id": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": "string" },
          "platform": { "type": "string" },
          "language_tags": { "type": "array", "items": { "type": "string" } },
          "cost_type": { "type": "string", "enum": ["Free", "Paid", "Freemium"] },
          "time_to_mastery": { "type": "string" },
          "prerequisite_skills": { "type": "array", "items": { "type": "string" } },
          "industry_recognition": { "type": "string" },
          "related_career_ids": { "type": "array", "items": { "type": "string" } },
          "provenance": { "$ref": "#/$defs/provenance" },
          "freshness": { "$ref": "#/$defs/freshness" },
          "contradiction_handling": { "$ref": "#/$defs/contradiction_handling" }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "required": ["sources", "confidence"],
      "properties": {
        "sources": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "freshness": {
      "type": "object",
      "required": ["last_verified_on", "review_cycle_days"],
      "properties": {
        "last_verified_on": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "review_cycle_days": { "type": "integer", "minimum": 1, "maximum": 365 }
      },
      "additionalProperties": true
    },
    "contradiction_handling": {
      "type": "object",
      "required": ["status", "resolution_policy", "conflicting_source_count"],
      "properties": {
        "status": { "type": "string", "enum": ["none", "under_review", "resolved"] },
        "resolution_policy": {
          "type": "string",
          "enum": ["higher_confidence_wins", "manual_editor_review", "latest_verified_source"]
        },
        "conflicting_source_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "quality_policy": {
      "type": "object",
      "required": ["confidence_scale", "freshness_sla_days", "contradiction_rules"],
      "properties": {
        "confidence_scale": { "type": "string" },
        "freshness_sla_days": { "type": "integer", "minimum": 1, "maximum": 365 },
        "contradiction_rules": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
