{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pehchaan-careers.local/schemas/financial_aid.schema.json",
  "type": "object",
  "required": ["meta", "financial_aid"],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "schema_version",
        "generated_on",
        "source_files",
        "quality_metadata",
        "language_coverage",
        "funding_friction_dimensions",
        "quality_policy"
      ],
      "properties": {
        "schema_version": { "type": "string" },
        "generated_on": { "type": "string" },
        "source_files": { "type": "array", "items": { "type": "string" } },
        "quality_metadata": {
          "type": "object",
          "required": ["confidence_scale", "freshness_sla_days"],
          "properties": {
            "confidence_scale": { "type": "string" },
            "freshness_sla_days": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": true
        },
        "language_coverage": {
          "type": "object",
          "required": ["supported_languages"],
          "properties": {
            "supported_languages": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        },
        "funding_friction_dimensions": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "quality_policy": { "$ref": "#/$defs/quality_policy" }
      },
      "additionalProperties": true
    },
    "financial_aid": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "aid_id",
          "name",
          "disbursement_reliability",
          "application_complexity",
          "language_tags",
          "funding_friction",
          "provenance",
          "freshness",
          "contradiction_handling"
        ],
        "properties": {
          "aid_id": { "type": "string" },
          "name": { "type": "string" },
          "provider": { "type": "string" },
          "disbursement_reliability": { "type": "string" },
          "hidden_eligibility": { "type": "array", "items": { "type": "string" } },
          "application_complexity": { "type": "integer", "minimum": 1, "maximum": 5 },
          "language_tags": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "funding_friction": {
            "type": "object",
            "required": ["document_burden", "timeline_uncertainty", "disbursement_risk", "hidden_eligibility_risk"],
            "properties": {
              "document_burden": { "type": "integer", "minimum": 1, "maximum": 5 },
              "timeline_uncertainty": { "type": "integer", "minimum": 1, "maximum": 5 },
              "disbursement_risk": { "type": "integer", "minimum": 1, "maximum": 5 },
              "hidden_eligibility_risk": { "type": "integer", "minimum": 1, "maximum": 5 }
            },
            "additionalProperties": false
          },
          "linked_career_ids": { "type": "array", "items": { "type": "string" } },
          "linked_exam_ids": { "type": "array", "items": { "type": "string" } },
          "provenance": { "$ref": "#/$defs/provenance" },
          "freshness": { "$ref": "#/$defs/freshness" },
          "contradiction_handling": { "$ref": "#/$defs/contradiction_handling" }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "required": ["sources", "confidence"],
      "properties": {
        "sources": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "freshness": {
      "type": "object",
      "required": ["last_verified_on", "review_cycle_days"],
      "properties": {
        "last_verified_on": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "review_cycle_days": { "type": "integer", "minimum": 1, "maximum": 365 }
      },
      "additionalProperties": true
    },
    "contradiction_handling": {
      "type": "object",
      "required": ["status", "resolution_policy", "conflicting_source_count"],
      "properties": {
        "status": { "type": "string", "enum": ["none", "under_review", "resolved"] },
        "resolution_policy": {
          "type": "string",
          "enum": ["higher_confidence_wins", "manual_editor_review", "latest_verified_source"]
        },
        "conflicting_source_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "quality_policy": {
      "type": "object",
      "required": ["confidence_scale", "freshness_sla_days", "contradiction_rules"],
      "properties": {
        "confidence_scale": { "type": "string" },
        "freshness_sla_days": { "type": "integer", "minimum": 1, "maximum": 365 },
        "contradiction_rules": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
