{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pehchaancareers.in/schemas/pehchaan_college_registry.schema.json",
  "title": "Pehchaan College Registry",
  "description": "Normalized college registry used by College Finder and Plan B college discovery.",
  "type": "object",
  "required": [
    "meta",
    "taxonomies",
    "state_neighbors",
    "colleges",
    "college_programs"
  ],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "version",
        "last_updated",
        "disclaimer",
        "data_notes",
        "sources"
      ],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "last_updated": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "disclaimer": {
          "type": "string",
          "minLength": 20
        },
        "data_notes": {
          "type": "string"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pipeline_stats": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "total_colleges": {
              "type": "integer",
              "minimum": 0
            },
            "total_programs": {
              "type": "integer",
              "minimum": 0
            },
            "stale_record_count": {
              "type": "integer",
              "minimum": 0
            },
            "last_pipeline_run": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            }
          }
        }
      }
    },
    "taxonomies": {
      "type": "object",
      "required": [
        "streams",
        "courses",
        "states",
        "geography_lenses",
        "admission_exams"
      ],
      "additionalProperties": false,
      "properties": {
        "streams": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/idLabel"
          }
        },
        "courses": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "label",
              "stream_ids"
            ],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "minLength": 2
              },
              "label": {
                "type": "string",
                "minLength": 2
              },
              "stream_ids": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "aliases": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "states": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "label"
            ],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "minLength": 2
              },
              "label": {
                "type": "string",
                "minLength": 2
              },
              "only_for_lens": {
                "type": "string",
                "enum": [
                  "national_level",
                  "state_comfort"
                ]
              }
            }
          }
        },
        "geography_lenses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/idLabel"
          }
        },
        "admission_exams": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/idLabel"
          }
        }
      }
    },
    "state_neighbors": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "colleges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "state_id",
          "city",
          "type",
          "contacts",
          "highlights",
          "verification"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 2
          },
          "name": {
            "type": "string",
            "minLength": 2
          },
          "state_id": {
            "type": "string",
            "minLength": 2
          },
          "city": {
            "type": "string",
            "minLength": 2
          },
          "type": {
            "type": "string",
            "minLength": 2
          },
          "ownership": {
            "type": "string"
          },
          "programs_verified": {
            "type": "boolean",
            "description": "When true, College Finder hides catalogue-heuristic programme rows for this college."
          },
          "confidence_level": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "contact_missing_reason": {
            "type": "string"
          },
          "contacts": {
            "type": "object",
            "required": [
              "website"
            ],
            "additionalProperties": false,
            "properties": {
              "website": {
                "type": "string",
                "pattern": "^https?://"
              },
              "email": {
                "type": "string"
              },
              "phone": {
                "type": "string"
              }
            }
          },
          "highlights": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "founded": {
                "type": "string"
              },
              "notable_alumni": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "best_for": {
                "type": "string"
              },
              "specialization": {
                "type": "string"
              },
              "unique_point": {
                "type": "string"
              },
              "why_choose": {
                "type": "string"
              },
              "notes": {
                "type": "string"
              }
            }
          },
          "verification": {
            "type": "object",
            "required": [
              "last_verified_on",
              "source_urls"
            ],
            "additionalProperties": false,
            "properties": {
              "nirf_band": {
                "type": "string"
              },
              "last_verified_on": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "source_urls": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^https?://"
                }
              }
            }
          },
          "cost_band": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "living_city_band": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "unknown"
                ]
              },
              "hostel_context": {
                "type": "string",
                "enum": [
                  "likely",
                  "mixed",
                  "limited",
                  "unknown"
                ]
              },
              "monthly_budget_min": {
                "type": "integer",
                "minimum": 0
              },
              "monthly_budget_max": {
                "type": "integer",
                "minimum": 0
              },
              "method": {
                "type": "string",
                "enum": [
                  "heuristic",
                  "manual"
                ]
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "last_updated": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "notes": {
                "type": "string"
              }
            }
          },
          "recognition": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "university_status": {
                "type": "string",
                "enum": [
                  "ugc",
                  "state_act",
                  "deemed",
                  "autonomous",
                  "private_university",
                  "unknown"
                ]
              },
              "regulators_required": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "regulators_verified": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "verification_urls": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^https?://"
                }
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "last_updated": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "notes": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "college_programs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "college_id",
          "stream_id",
          "course_id",
          "geography_lens_ids",
          "admission_exam_ids",
          "admission_routes",
          "availability",
          "last_verified_on"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 2
          },
          "college_id": {
            "type": "string",
            "minLength": 2
          },
          "stream_id": {
            "type": "string",
            "minLength": 2
          },
          "course_id": {
            "type": "string",
            "minLength": 2
          },
          "program_name": {
            "type": "string",
            "description": "Human-readable programme label shown in College Finder (optional)."
          },
          "geography_lens_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "admission_exam_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "admission_routes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "availability": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "is_active": {
                "type": "boolean"
              },
              "state_specific": {
                "type": "boolean"
              },
              "confidence_level": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "notes": {
                "type": "string"
              },
              "catalogue_expansion": {
                "type": "boolean",
                "description": "True when this row is catalogue-style enrichment, not curator-verified against a brochure."
              }
            }
          },
          "last_verified_on": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "admission_route": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "primary": {
                "type": "string",
                "enum": [
                  "state_counselling",
                  "all_india_counselling",
                  "institute_level",
                  "mixed",
                  "verify"
                ]
              },
              "exam_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "pathways": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "verification_url": {
                "type": "string",
                "pattern": "^https?://"
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "last_updated": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "notes": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "idLabel": {
      "type": "object",
      "required": [
        "id",
        "label"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 2
        },
        "label": {
          "type": "string",
          "minLength": 2
        }
      }
    }
  }
}
